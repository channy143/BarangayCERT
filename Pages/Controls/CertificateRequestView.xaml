<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="MauiApp1.Pages.Controls.CertificateRequestView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Frame
        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkSection}}"
        BorderColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
        Padding="15"
        CornerRadius="10"
        Margin="15,5">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto">
            <!-- Certificate Type -->
            <Label
                Grid.Row="0"
                Grid.Column="0"
                Text="{Binding Request.CertificateType}"
                FontSize="16"
                FontAttributes="Bold"
                TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

            <!-- Status Badge -->
            <Frame
                Grid.Row="0"
                Grid.Column="1"
                BackgroundColor="{Binding Request.Status, Converter={StaticResource StatusToColorConverter}}"
                Padding="8,4"
                CornerRadius="12">
                <Label
                    Text="{Binding Request.StatusDisplay}"
                    FontSize="12"
                    TextColor="White"
                    FontAttributes="Bold" />
            </Frame>

            <!-- Purpose -->
            <Label
                Grid.Row="1"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Text="{Binding Request.Purpose}"
                FontSize="14"
                TextColor="{AppThemeBinding Light={StaticResource Gray600}, Dark={StaticResource Gray400}}"
                MaxLines="2"
                LineBreakMode="TailTruncation"
                Margin="0,5" />

            <!-- Requester Info -->
            <HorizontalStackLayout
                Grid.Row="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="5">
                <Label
                    Text="Requested by:"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}" />
                <Label
                    Text="{Binding Request.Requester.Email}"
                    FontSize="12"
                    FontAttributes="Bold"
                    TextColor="{AppThemeBinding Light={StaticResource Gray700}, Dark={StaticResource Gray300}}" />
                <Label
                    Text="|"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource Gray400}, Dark={StaticResource Gray500}}" />
                <Label
                    Text="{Binding Request.RequestDateDisplay}"
                    FontSize="12"
                    TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray500}}" />
            </HorizontalStackLayout>

            <!-- Action Buttons -->
            <HorizontalStackLayout
                Grid.Row="3"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Spacing="10"
                Margin="0,10,0,0">

                <Button
                    Text="View"
                    FontSize="12"
                    Padding="15,8"
                    Command="{Binding ViewDetailsCommand}"
                    CommandParameter="{Binding ViewDetailsCommandParameter}"
                    BackgroundColor="{AppThemeBinding Light=#E0E0E0, Dark=#404040}"
                    TextColor="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />

                <Button
                    Text="Approve"
                    FontSize="12"
                    Padding="15,8"
                    Command="{Binding ApproveCommand}"
                    CommandParameter="{Binding ApproveCommandParameter}"
                    BackgroundColor="#28A745"
                    TextColor="White"
                    IsVisible="{Binding Request.IsPending}" />

                <Button
                    Text="Delete"
                    FontSize="12"
                    Padding="15,8"
                    Command="{Binding DeleteCommand}"
                    CommandParameter="{Binding DeleteCommandParameter}"
                    BackgroundColor="#DC3545"
                    TextColor="White" />
            </HorizontalStackLayout>
        </Grid>
    </Frame>
</ContentView>
